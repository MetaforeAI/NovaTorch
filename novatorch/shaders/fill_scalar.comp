#version 450

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) writeonly buffer Out { float out_data[]; };

layout(push_constant) uniform PC {
    uint numel;
    float value;
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= numel) return;

    out_data[idx] = value;
}
